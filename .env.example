# レビュー対象のコミットハッシュ（手動指定時）
GIT_REVIEW_TOOL_COMMIT=abc1234

# 比較元コミット（省略可能）
# GIT_REVIEW_TOOL_BASE=def5678

# BASE自動検出に使うブランチ名（省略可能）
# GIT_REVIEW_TOOL_AUTO_BASE_BRANCH=main

# ターゲット自動検出キーワード（省略可能）
# base..HEAD のコミットメッセージにこの文字列を含む最新コミットを対象にします
# GIT_REVIEW_TOOL_AUTO_TARGET_MSG_KWD=[review]

# レビュー対象リポジトリのパス（デフォルト: カレントディレクトリ）
# GIT_REVIEW_TOOL_REPO_PATH=/path/to/your/repo

# Flask サーバのポート（デフォルト: 5000）
# GIT_REVIEW_TOOL_PORT=5000

# 差分のエンコーディング（省略時は自動検出）
# GIT_REVIEW_TOOL_ENCODING=euc-jp

# 動作モード（省略時: serve）
# serve: Flaskサーバを起動してブラウザレビュー（デフォルト）
# check: 全hunkのレビュー完了状態を確認して終了（exit 0: 完了, exit 1: 未完了）
# GIT_REVIEW_TOOL_MODE=check
